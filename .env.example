# ============================================================
#  FamilyHub — Variáveis de Ambiente (EXEMPLO)
#
#  INSTRUÇÃO: Copie este arquivo para .env e preencha com
#  seus próprios valores. NUNCA suba o .env ao repositório.
#
#  cp .env.example .env
# ============================================================

# ─── Banco de dados MySQL ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=familyhub
DB_USER=root
DB_PASS=COLOQUE_SUA_SENHA_AQUI

# ─── Segurança ───────────────────────────────────────────────
# Gere uma chave aleatória forte. Exemplo no terminal:
#   php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_FORTE_AQUI

# ─── Aplicação ───────────────────────────────────────────────
# URL da aplicação (sem barra no final)
APP_URL=http://localhost

# Ambiente: development | production
APP_ENV=development

# ─── Rate Limiting (proteção contra brute force no login) ────
# RATE_LIMIT_ATTEMPTS = tentativas antes de bloquear (padrão: 5)
# RATE_LIMIT_WINDOW   = janela de contagem em minutos (padrão: 15)
# RATE_LIMIT_LOCKOUT  = duração do bloqueio em minutos (padrão: 30)
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=15
RATE_LIMIT_LOCKOUT=30

# ─── Proxy Reverso ───────────────────────────────────────────
# Defina como "true" APENAS se houver um proxy reverso confiável
# (Cloudflare, Nginx, etc.) na frente do servidor.
# Com "false", o IP real da conexão TCP é sempre usado (mais seguro).
TRUSTED_PROXY=false
